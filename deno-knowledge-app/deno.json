{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write=$HOME/.cache --allow-run=git,backlog,uv,ccusage,open --allow-env main.ts",
    "start": "deno run --allow-net --allow-read --allow-write=$HOME/.cache --allow-run=git,backlog,uv,ccusage,open --allow-env main.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env",
    "check": "deno check main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/html": "jsr:@std/html@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1"
  },
  "exclude": ["assets"],
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
